<Window x:Class="AIAgentHarryDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIAgentHarryDemo"
        mc:Ignorable="d"
        Title="AI Agent Harry Demo" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid VerticalAlignment="Top" Background="{DynamicResource {x:Static SystemColors.MenuBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Menu Grid.Column="0">
                <MenuItem Header="_Kontakt" Click="ContactMenuItem_Click" />
                <MenuItem Header="_Extras" />
            </Menu>
            <Menu Grid.Column="1">
                <MenuItem Header="_Hilfe" />
            </Menu>
        </Grid>

        <DataGrid x:Name="ContactsDataGrid"
                  Grid.Row="1"
                  Margin="12"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Anrede"
                                    Width="Auto"
                                    Binding="{Binding Salutation}" />
                <DataGridTextColumn Header="Vorname"
                                    Width="*"
                                    Binding="{Binding FirstName}" />
                <DataGridTextColumn Header="Name"
                                    Width="*"
                                    Binding="{Binding LastName}" />
                <DataGridTextColumn Header="Position"
                                    Width="*"
                                    Binding="{Binding Position}" />
                <DataGridTextColumn Header="Telefonnummer"
                                    Width="*"
                                    Binding="{Binding PhoneNumber}" />
                <DataGridTextColumn Header="E-Mail-Adresse"
                                    Width="1.5*"
                                    Binding="{Binding EmailAddress}" />
                <DataGridTextColumn Header="Bemerkungen"
                                    Width="2*"
                                    Binding="{Binding Notes}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
