<Window x:Class="AIAgentHarryDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIAgentHarryDemo"
        mc:Ignorable="d"
        Title="AI Agent Harry Demo" Height="450" Width="800">
    <Grid>
        <Grid VerticalAlignment="Top" Background="{DynamicResource {x:Static SystemColors.MenuBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <Button Content="Neuer Kontakt"
                        Margin="4,2"
                        Padding="8,2"
                        VerticalAlignment="Center" />
                <Menu>
                    <MenuItem Header="_Kontakt" Click="ContactMenuItem_Click" />
                    <MenuItem Header="_Extras" />
                </Menu>
            </DockPanel>
            <Menu Grid.Column="1">
                <MenuItem Header="_Hilfe" />
            </Menu>
        </Grid>
    </Grid>
</Window>
