<Window x:Class="AIAgentHarryDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIAgentHarryDemo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.MenuBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Menu Grid.Column="0">
                <MenuItem x:Name="ContactMenuItem"
                          Header="_Kontakt"
                          AutomationProperties.AutomationId="ContactMenuItem"
                          Click="ContactMenuItem_Click" />
            </Menu>
            <Menu Grid.Column="1">
                <MenuItem x:Name="HelpMenuItem"
                          Header="_Hilfe"
                          AutomationProperties.AutomationId="HelpMenuItem" />
            </Menu>
        </Grid>

        <ListBox x:Name="ContactListBox"
                 AutomationProperties.AutomationId="ContactListBox"
                 Grid.Row="1"
                 Margin="16"
                 FontSize="16">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Margin="4"
                               Text="{Binding}"
                               TextWrapping="Wrap" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
