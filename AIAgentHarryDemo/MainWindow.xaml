<Window x:Class="AIAgentHarryDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIAgentHarryDemo"
        mc:Ignorable="d"
        Title="AI Agent Harry Demo" Height="450" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.MenuBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <Button Content="Neuer Kontakt"
                        Margin="4,2"
                        Padding="8,2"
                        VerticalAlignment="Center" />
                <Menu>
                    <MenuItem Header="_Kontakt" Click="ContactMenuItem_Click" />
                    <MenuItem Header="_Extras" />
                </Menu>
            </DockPanel>
            <Menu Grid.Column="1">
                <MenuItem Header="_Hilfe" />
            </Menu>
        </Grid>

        <Border x:Name="SelectedContactBorder"
                Grid.Row="1"
                MaxWidth="460"
                Margin="10,8,10,4"
                Padding="10"
                HorizontalAlignment="Left"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="1"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Anrede" />
                <TextBlock x:Name="SelectedSalutationTextBlock" Grid.Row="0" Grid.Column="1" Margin="12,0,16,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="Vorname" />
                <TextBlock x:Name="SelectedFirstNameTextBlock" Grid.Row="1" Grid.Column="1" Margin="12,0,16,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="Name" />
                <TextBlock x:Name="SelectedLastNameTextBlock" Grid.Row="2" Grid.Column="1" Margin="12,0,16,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="Position" />
                <TextBlock x:Name="SelectedPositionTextBlock" Grid.Row="3" Grid.Column="1" Margin="12,0,16,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" Text="Telefon" />
                <TextBlock x:Name="SelectedPhoneNumberTextBlock" Grid.Row="4" Grid.Column="1" Margin="12,0,16,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="5" Grid.Column="0" FontWeight="SemiBold" Text="E-Mail" />
                <TextBlock x:Name="SelectedEmailAddressTextBlock" Grid.Row="5" Grid.Column="1" Margin="12,0,16,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="6" Grid.Column="0" FontWeight="SemiBold" Text="Bemerkungen" />
                <TextBlock x:Name="SelectedRemarksTextBlock" Grid.Row="6" Grid.Column="1" Margin="12,0,16,0" TextWrapping="Wrap" />

                <Button Grid.Row="0"
                        Grid.RowSpan="7"
                        Grid.Column="2"
                        MinWidth="90"
                        Padding="12,4"
                        VerticalAlignment="Top"
                        Content="Duplizieren"
                        Click="DuplicateContactButton_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="Suchbegriff:" />
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     MinWidth="220"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     KeyDown="SearchTextBox_KeyDown" />
            <Button Grid.Column="2"
                    MinWidth="90"
                    Padding="12,4"
                    Content="Suche"
                    Click="SearchButton_Click" />
        </Grid>

        <DataGrid x:Name="ContactsDataGrid"
                  Grid.Row="4"
                  Margin="12,0,12,12"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="ContactsDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Anrede" Binding="{Binding Salutation}" Width="80" />
                <DataGridTextColumn Header="Vorname" Binding="{Binding FirstName}" Width="*" MinWidth="110" />
                <DataGridTextColumn Header="Name" Binding="{Binding LastName}" Width="*" MinWidth="120" />
                <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="*" MinWidth="130" />
                <DataGridTextColumn Header="Telefon" Binding="{Binding PhoneNumber}" Width="140" />
                <DataGridTextColumn Header="E-Mail" Binding="{Binding EmailAddress}" Width="*" MinWidth="180" />
                <DataGridTextColumn Header="Bemerkungen" Binding="{Binding Remarks}" Width="2*" MinWidth="180" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
