<Window x:Class="AIAgentHarryDemo.ContactDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kontakt"
        Height="460"
        Width="480"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,4"
                   Text="Anrede:" />
        <ComboBox x:Name="SalutationComboBox"
                  Grid.Row="1"
                  Width="120"
                  Margin="0,0,0,8"
                  HorizontalAlignment="Left">
            <ComboBoxItem Content="Herr" />
            <ComboBoxItem Content="Frau" />
            <ComboBoxItem Content="Divers" />
        </ComboBox>

        <Grid Grid.Row="2"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,0,4"
                       Text="Vorname:" />
            <TextBox x:Name="FirstNameTextBox"
                     Grid.Row="1"
                     Grid.Column="0" />

            <TextBlock Grid.Row="0"
                       Grid.Column="2"
                       Margin="0,0,0,4"
                       Text="Name:" />
            <TextBox x:Name="LastNameTextBox"
                     Grid.Row="1"
                     Grid.Column="2" />
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,0,0,4"
                   Text="Position:" />
        <TextBox x:Name="PositionTextBox"
                 Grid.Row="4"
                 Margin="0,0,0,8" />

        <Grid Grid.Row="5"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,0,4"
                       Text="Telefonnummer:" />
            <TextBox x:Name="PhoneTextBox"
                     Grid.Row="1"
                     Grid.Column="0" />

            <TextBlock Grid.Row="0"
                       Grid.Column="2"
                       Margin="0,0,0,4"
                       Text="E-Mail-Adresse:" />
            <TextBox x:Name="EmailTextBox"
                     Grid.Row="1"
                     Grid.Column="2" />
        </Grid>

        <TextBlock Grid.Row="6"
                   Margin="0,0,0,4"
                   Text="Bemerkungen:" />
        <TextBox x:Name="RemarksTextBox"
                 Grid.Row="7"
                 MinHeight="90"
                 Margin="0,0,0,16"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="8"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button MinWidth="80"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Content="OK"
                    Click="OkButton_Click" />
            <Button MinWidth="80"
                    IsCancel="True"
                    Content="Abbrechen" />
        </StackPanel>
    </Grid>
</Window>
