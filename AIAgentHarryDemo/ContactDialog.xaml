<Window x:Class="AIAgentHarryDemo.ContactDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kontakt"
        Height="460"
        Width="480"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Center"
                   Text="Anrede:" />
        <ComboBox x:Name="SalutationComboBox"
                  Grid.Row="0"
                  Grid.Column="1"
                  Width="160"
                  Margin="0,0,0,8"
                  HorizontalAlignment="Left">
            <ComboBoxItem Content="Herr" />
            <ComboBoxItem Content="Frau" />
            <ComboBoxItem Content="Divers" />
        </ComboBox>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Center"
                   Text="Vorname:" />
        <TextBox x:Name="FirstNameTextBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,0,0,8" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Center"
                   Text="Name:" />
        <TextBox x:Name="LastNameTextBox"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="0,0,0,8" />

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Center"
                   Text="Position:" />
        <TextBox x:Name="PositionTextBox"
                 Grid.Row="3"
                 Grid.Column="1"
                 Margin="0,0,0,8" />

        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Center"
                   Text="Telefonnummer:" />
        <TextBox x:Name="PhoneTextBox"
                 Grid.Row="4"
                 Grid.Column="1"
                 Margin="0,0,0,8" />

        <TextBlock Grid.Row="5"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Center"
                   Text="E-Mail-Adresse:" />
        <TextBox x:Name="EmailTextBox"
                 Grid.Row="5"
                 Grid.Column="1"
                 Margin="0,0,0,8" />

        <TextBlock Grid.Row="6"
                   Grid.Column="0"
                   Margin="0,0,12,8"
                   VerticalAlignment="Top"
                   Text="Bemerkungen:" />
        <TextBox x:Name="RemarksTextBox"
                 Grid.Row="6"
                 Grid.Column="1"
                 MinHeight="90"
                 Margin="0,0,0,16"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="7"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button MinWidth="80"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Content="OK"
                    Click="OkButton_Click" />
            <Button MinWidth="80"
                    IsCancel="True"
                    Content="Abbrechen" />
        </StackPanel>
    </Grid>
</Window>
